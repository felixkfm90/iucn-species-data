* text=auto

# Plattformunabhängige Quell-, Daten- und Dokumentdateien
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Windows-Start- und Wartungsskripte
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.vbs text eol=crlf

# Binärdateien niemals normalisieren
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.mp3 binary
*.psd binary
*.zip binary
